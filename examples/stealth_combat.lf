// 상호 배제로 상태가 봉쇄되는 모순 (D6 — 불리언 상태 변수)
// 검사: ludoforge check examples/stealth_combat.lf  (모순 1건, 종료코드 1)
domain {
    stealthed: bool
    attacking: bool
}

constraint combat_forces_attack:
    author "planner_B"
    desc "전투 진입 시 항상 공격 상태"
    then attacking

constraint stealth_attack_mutex:
    author "planner_B"
    desc "은신과 공격은 동시에 성립할 수 없다"
    then not (stealthed and attacking)
