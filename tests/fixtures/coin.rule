# DTMC 픽스처(sim Phase 1) — 동전 누적. 도달 상태마다 enabled 전이가 정확히 1개라
# DTMC 게이트(D19)를 통과한다. init이 모든 변수를 고정(자유변수 없음).
#
#   flips<5 & playing  → flip만   (0.5 앞=gold+1 / 0.5 뒤=무변화)
#   flips>=5 & playing → finish만  (status=done)
#   done               → done_absorb만 (흡수 — 지평까지 절단)
domain:
  variables:
    gold:   { type: int, min: 0, max: 5 }
    flips:  { type: int, min: 0, max: 5 }
    status: { type: enum, values: [playing, done] }

init: "gold == 0 and flips == 0 and status == playing"

transitions:
  - id: flip
    when: "status == playing and flips < 5"
    outcomes:
      - { weight: 0.5, then: "next.gold == gold + 1 and next.flips == flips + 1" }
      - { weight: 0.5, then: "next.flips == flips + 1" }
  - id: finish
    when: "status == playing and flips >= 5"
    then: "next.status == done"
  - id: done_absorb
    when: "status == done"
    then: "next.status == done"

checks:
  - id: rich
    kind: reachable
    desc: "5번 던져 4 이상 모을 수 있는가"
    that: "gold >= 4"
