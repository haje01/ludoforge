// D31 픽스처의 쌍둥이 — ghost_counter.lf에서 ghost(steps)를 손으로 걷어낸 판.
// 비-ghost 의미(bmc 지위·sim 추정)가 ghost판과 비트 동일해야 한다.
domain {
    gold:   int 0..5
    status: enum { run, done }
}
init: gold == 0 and status == run
transition earn:
    when status == run and gold < 5
    outcomes:
        0.5 -> gold = gold + 1
        0.5 -> gold = gold
transition finish:
    when status == run and gold >= 5
    then status = done
transition done_absorb: when status == done then status = done
check can_finish reachable: status == done
check gold_ok invariant: gold >= 0
check no_stuck no_deadlock
