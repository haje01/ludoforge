# CLAUDE.md §4 예시 룰셋 (로더 테스트용)
domain:
  variables:
    level: { type: int, min: 1, max: 100 }
    hp:    { type: int, min: 0 }
    role:  { type: enum, values: [warrior, mage, archer] }

rules:
  - id: warrior_hp_formula
    author: planner_A
    desc: "전사 최대 HP는 레벨당 100"
    when: "role == warrior"
    then: "hp == level * 100"

  - id: global_hp_cap
    author: planner_B
    desc: "모든 캐릭터 HP는 5000을 넘지 않는다"
    then: "hp <= 5000"
