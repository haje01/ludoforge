// 모순(range violation): 전사 HP 공식 + 낮은 상한 → 전사는 레벨 50까지만 가능.
// 범인 룰: warrior_hp_formula, global_hp_cap. 종속 변수 hp는 거짓양성으로 잡히면 안 됨.
domain {
    level: int 1..100
    hp:    int 0..
    role:  enum { warrior, mage, archer }
}

constraint warrior_hp_formula:
    when role == warrior
    then hp == level * 100

constraint global_hp_cap:
    then hp <= 5000
