// 실수 확률 over-constraint 모순 (LRA, D7)
// 합이 1이어야 하는데 두 확률 모두 0.7 이상이면 1.4 > 1 이라 어떤 값으로도 불가.
domain {
    common: real 0..1
    rare:   real 0..1
}

constraint prob_sum_one:
    author "planner_loot"
    desc "확률의 합은 1"
    then common + rare == 1.0

constraint common_floor:
    author "planner_loot"
    desc "common은 최소 0.7"
    then common >= 0.7

constraint rare_floor:
    author "planner_reward"
    desc "rare도 최소 0.7"
    then rare >= 0.7
