// 상호 배제로 상태가 봉쇄되는 모순 (D6)
// attacking이 항상 true로 강제되고, 은신과 공격이 상호 배제이므로
// stealthed=true 상태는 영영 도달 불가능하다.
domain {
    stealthed: bool
    attacking: bool
}

constraint always_attacking:
    author "planner_A"
    desc "전투 중에는 항상 공격 상태"
    then attacking

constraint stealth_mutex:
    author "planner_B"
    desc "은신과 공격은 동시에 성립할 수 없다"
    then not (stealthed and attacking)
