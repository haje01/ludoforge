# 모순(unreachable enum): ghost는 hp==0인데 전역 룰이 hp>=1을 요구 → ghost 도달 불가.
# 범인 룰: ghost_no_hp, must_have_hp.
domain:
  variables:
    hp:   { type: int, min: 0, max: 100 }
    role: { type: enum, values: [normal, ghost] }

rules:
  - id: ghost_no_hp
    when: "role == ghost"
    then: "hp == 0"
  - id: must_have_hp
    then: "hp >= 1"
