# 상호 배제가 있으나 모든 상태가 도달 가능한 정합 케이스 (D6)
# 두 상태 모두 자유 — 동시 true만 막힐 뿐 각 상태는 단독으로 도달 가능하다.
domain:
  variables:
    stealthed: { type: bool }
    attacking: { type: bool }

constraints:
  - id: stealth_mutex
    author: planner_A
    desc: "은신과 공격은 동시에 성립할 수 없다"
    then: "not (stealthed and attacking)"
