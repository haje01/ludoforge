// 실수 확률 정합 케이스 (LRA, D7 / D9)
// 합=1만 두면 common은 0(rare=1)·1(rare=0) 양 끝점에 도달 가능 → 선언 [0,1]이 봉쇄되지
// 않는다. (D9 끝점 검사: floor/cap이 선언 끝점을 막으면 모순으로 잡히므로 여기선 두지 않음.)
domain {
    common: real 0..1
    rare:   real 0..1
}

constraint prob_sum_one:
    author "planner_loot"
    desc "확률의 합은 1"
    then common + rare == 1.0
