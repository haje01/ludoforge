# 실수 확률 정합 케이스 (LRA, D7)
# common 최소 0.6이어도 rare=0.4로 합 1을 맞출 수 있어 모순 없음.
domain:
  variables:
    common: { type: real, min: 0, max: 1 }
    rare:   { type: real, min: 0, max: 1 }

rules:
  - id: prob_sum_one
    author: planner_loot
    desc: "확률의 합은 1"
    then: "common + rare == 1.0"

  - id: common_floor
    author: planner_loot
    desc: "common은 최소 0.6"
    then: "common >= 0.6"
